generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(cuid())
  fullName    String   @map("full_name")
  email       String
  phone       String?
  companyName String?  @map("company_name")
  inquiryType String   @map("inquiry_type") // consultation, inquiry, partnership
  message     String
  source      String   @default("website") // website, chatbot, whatsapp
  status      String   @default("new")     // new, contacted, qualified, closed
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("leads")
}

model ChatSession {
  id        String   @id @default(cuid())
  sessionId String   @unique @map("session_id")
  messages  Json     @default("[]")
  leadId    String?  @map("lead_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("chat_sessions")
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model Blog {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  content        String    @db.Text
  excerpt        String?   @db.Text
  featuredImage  String?   @map("featured_image")
  author         String
  status         String    @default("draft") // draft, published, scheduled
  categoryId     String?   @map("category_id")
  category       Category? @relation(fields: [categoryId], references: [id])
  tags           String[]  @default([])
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @db.Text @map("seo_description")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  publishedAt    DateTime? @map("published_at")

  @@map("blogs")
}

model VideoBlog {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  description    String?   @db.Text
  videoUrl       String    @map("video_url") // YouTube url or internal upload url
  thumbnail      String?
  categoryId     String?   @map("category_id")
  category       Category? @relation(fields: [categoryId], references: [id])
  tags           String[]  @default([])
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @db.Text @map("seo_description")
  status         String    @default("draft") // draft, published, scheduled
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  publishedAt    DateTime? @map("published_at")

  @@map("video_blogs")
}

model Category {
  id         String      @id @default(cuid())
  name       String      @unique
  slug       String      @unique
  blogs      Blog[]
  videoBlogs VideoBlog[]
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@map("categories")
}

model MediaAsset {
  id         String   @id @default(cuid())
  filename   String
  type       String   // image, video, document
  url        String   @unique
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  @@map("media_assets")
}
